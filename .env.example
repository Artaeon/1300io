# =============================================================================
# 1300.io Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# Required
# -----------------------------------------------------------------------------
# Secret key for signing JWT tokens. Generate with: openssl rand -base64 32
JWT_SECRET=

# Database connection string.
# SQLite (development): file:./dev.db
# PostgreSQL (production): postgresql://user:password@host:5432/dbname
DATABASE_URL="file:./dev.db"

# Postgres credentials (used by docker-compose.prod.yml for the db service).
# Required when deploying with the production compose file.
POSTGRES_DB=onorm1300
POSTGRES_USER=onorm1300
POSTGRES_PASSWORD=

# Optional
# -----------------------------------------------------------------------------
# Express server port
PORT=3000

# Environment: development | production
NODE_ENV=development

# Allowed CORS origin. Set to your frontend domain in production.
FRONTEND_URL=http://localhost:5173

# Directory for uploaded inspection photos
UPLOAD_DIR=./uploads

# Logging level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Development seed user (used by seed_user.js only)
# -----------------------------------------------------------------------------
# These are only used when running `node seed_user.js` to bootstrap
# an initial admin account. Not used at runtime.
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=changeme-use-a-strong-password
ADMIN_NAME=Admin
