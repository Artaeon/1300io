# =============================================================================
# 1300.io Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# Required
# -----------------------------------------------------------------------------
# Secret key for signing JWT tokens. Generate with: openssl rand -base64 32
JWT_SECRET=

# PostgreSQL connection string. Format:
#   postgresql://user:password@host:5432/dbname
# For docker-compose dev: postgresql://onorm1300:dev@db:5432/onorm1300_dev
DATABASE_URL="postgresql://onorm1300:dev@localhost:5432/onorm1300_dev"

# Postgres credentials (used by docker-compose.prod.yml for the db service).
# Required when deploying with the production compose file.
POSTGRES_DB=onorm1300
POSTGRES_USER=onorm1300
POSTGRES_PASSWORD=

# Optional
# -----------------------------------------------------------------------------
# Express server port
PORT=3000

# Environment: development | production
NODE_ENV=development

# Allowed CORS origin. Set to your frontend domain in production.
FRONTEND_URL=http://localhost:5173

# Directory for uploaded inspection photos
UPLOAD_DIR=./uploads

# Logging level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Prometheus metrics. In production, /metrics requires the bearer
# token below — configure your Prometheus scraper with the same value.
# Leave unset in dev to allow unauthenticated scraping.
METRICS_TOKEN=

# Optional error tracking. Install @sentry/node (server) / @sentry/react
# (client) and set these to enable. See docs/RUNBOOK.md.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_RELEASE=

# Impressum contact phone (optional, shown on /impressum).
# Leave unset to omit the phone line entirely.
VITE_IMPRESSUM_PHONE=

# Development seed user (used by seed_user.js only)
# -----------------------------------------------------------------------------
# These are only used when running `node seed_user.js` to bootstrap
# an initial admin account. Not used at runtime.
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=changeme-use-a-strong-password
ADMIN_NAME=Admin
