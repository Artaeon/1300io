generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id         Int        @id @default(autoincrement())
  name       String
  users      User[]
  properties Property[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model User {
  id             Int            @id @default(autoincrement())
  email          String         @unique
  password       String
  name           String
  role           String         @default("INSPECTOR") // ADMIN, MANAGER, INSPECTOR, READONLY
  organizationId Int?
  organization   Organization?  @relation(fields: [organizationId], references: [id])
  refreshTokens  RefreshToken[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([organizationId])
  @@index([role])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Property {
  id             Int               @id @default(autoincrement())
  address        String
  owner_name     String
  units_count    Int
  organizationId Int?
  organization   Organization?     @relation(fields: [organizationId], references: [id])
  inspections    Inspection[]
  defects        DefectTracking[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([organizationId])
  @@index([createdAt])
}

model Inspection {
  id              Int                @id @default(autoincrement())
  property_id     Int
  property        Property           @relation(fields: [property_id], references: [id])
  date            DateTime           @default(now())
  ended_at        DateTime?
  status          String             @default("DRAFT") // DRAFT, COMPLETED
  inspector_name  String
  results         InspectionResult[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([property_id])
  @@index([status])
  @@index([ended_at])
  @@index([property_id, status])
}

model ChecklistCategory {
  id         Int             @id @default(autoincrement())
  name       String
  sort_order Int             @default(0)
  items      ChecklistItem[]
  createdAt  DateTime        @default(now())
}

model ChecklistItem {
  id          Int               @id @default(autoincrement())
  category_id Int
  category    ChecklistCategory @relation(fields: [category_id], references: [id])
  text        String
  sort_order  Int               @default(0)
  results     InspectionResult[]
  defects     DefectTracking[]
  createdAt   DateTime          @default(now())

  @@index([category_id])
}

model InspectionResult {
  id                Int              @id @default(autoincrement())
  inspection_id     Int
  inspection        Inspection       @relation(fields: [inspection_id], references: [id])
  checklist_item_id Int
  checklist_item    ChecklistItem    @relation(fields: [checklist_item_id], references: [id])
  status            String           // OK, DEFECT, NOT_APPLICABLE
  comment           String?
  photo_url         String?
  defectsFound      DefectTracking[] @relation("DefectFirstFound")
  defectsResolved   DefectTracking[] @relation("DefectResolved")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([inspection_id])
  @@index([checklist_item_id])
  @@index([inspection_id, checklist_item_id])
}

model DefectTracking {
  id                    Int              @id @default(autoincrement())
  property_id           Int
  property              Property         @relation(fields: [property_id], references: [id])
  checklist_item_id     Int
  checklist_item        ChecklistItem    @relation(fields: [checklist_item_id], references: [id])
  first_found_result_id Int
  first_found_result    InspectionResult @relation("DefectFirstFound", fields: [first_found_result_id], references: [id])
  resolved_result_id    Int?
  resolved_result       InspectionResult? @relation("DefectResolved", fields: [resolved_result_id], references: [id])
  status                String           @default("OPEN") // OPEN, RESOLVED
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([property_id])
  @@index([checklist_item_id])
  @@index([status])
  @@index([property_id, status])
  @@index([first_found_result_id])
  @@index([resolved_result_id])
}

model AuditLog {
  id           Int      @id @default(autoincrement())
  action       String   // CREATE, UPDATE, DELETE
  entityType   String   // User, Property, Inspection, InspectionResult
  entityId     Int
  userId       Int?
  ipAddress    String?
  userAgent    String?
  previousData String?  // JSON string of previous state
  newData      String?  // JSON string of new state
  timestamp    DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([timestamp])
}
